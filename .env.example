# Production Environment Variables Example
# Set these in your deployment platform (e.g., Render, Vercel)

NODE_ENV=production
PORT=10000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/freelance-connect?retryWrites=true&w=majority

# Secret for JWT signing
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# The URL where your site is hosted (optional if same-origin)
CLIENT_URL=https://your-app-name.onrender.com
